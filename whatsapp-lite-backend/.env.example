# Server
PORT=5001
NODE_ENV=development

# MySQL (recommended for hosted providers like Railway)
# Example: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl=true
DATABASE_URL=

# MySQL (local / manual config alternative)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=whatsapp_lite
DB_USER=root
DB_PASSWORD=root

# Optional TLS for MySQL (often needed on hosted DBs)
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS (comma-separated).
# Supports exact origins and wildcards, e.g.:
#   http://localhost:5173,https://your-app.vercel.app,https://*.vercel.app
CORS_ORIGINS=http://localhost:5173
